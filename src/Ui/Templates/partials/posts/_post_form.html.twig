{# templates/partials/posts/_post_form.html.twig #}
{#
    Partial réutilisable pour création / édition d’un Post.

    Variables attendues :
    - form
    - submit_label
    - submit_class (optionnel)
#}

{{ form_start(form, {
    attr: {
        novalidate: 'novalidate',
        class: 'post-form'
    }
}) }}

    <div class="mb-4">
        {{ form_label(form.title) }}

        {{ form_widget(form.title, {
            attr: {
                class: 'form-control form-control-lg'
            }
        }) }}

        {{ form_errors(form.title) }}
    </div>

    <div class="mb-4">
        {{ form_label(form.content) }}

        {{ form_widget(form.content, {
            attr: {
                class: 'form-control'
            }
        }) }}

        {{ form_errors(form.content) }}
    </div>

    <div class="d-flex gap-2">
        <button
            type="submit"
            class="btn {{ submit_class|default('btn-primary') }}"
        >
            {{ submit_label }}
        </button>

        {% block post_form_cancel %}{% endblock %}
    </div>

{{ form_end(form) }}