{% extends 'base.html.twig' %}

{% block title %}Modifier le post{% endblock %}

{% block body %}
<div class="row justify-content-center">
    <div class="col-md-8">

        <h2 class="mb-4">
            ✏️ Modifier le post
        </h2>

        {% include 'partials/flash/_flash_messages.html.twig' %}

        {% include 'partials/posts/_post_form.html.twig' with {
            form: form,
            submit_label: 'Mettre à jour',
            submit_class: 'btn-success'
        } only %}

        {# ── Suppression du post ───────────────────────────── #}

        {% if is_granted('POST_DELETE', post) %}
            <div class="mt-4 pt-3 border-top text-end">

                <form
                    method="post"
                    action="{{ path('post_delete', { id: post.id }) }}"
                >
                    <input
                        type="hidden"
                        name="_token"
                        value="{{ csrf_token('delete' ~ post.id) }}"
                    >

                    <button
                        type="submit"
                        class="btn btn-sm btn-outline-danger"
                        onclick="return confirm('Supprimer définitivement ce post ?')"
                    >
                        🗑 Supprimer le post
                    </button>
                </form>

            </div>
        {% endif %}

    </div>
</div>
{% endblock %}